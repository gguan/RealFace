# FaceForge environment variable overrides
# Copy this file to .env and edit as needed

# Force a specific compute device: cuda | mps | cpu
# If unset, auto-detection is used (CUDA > MPS > CPU)
# FACEFORGE_DEVICE=cpu

# Override config file path (default: config/default.yaml)
# FACEFORGE_CONFIG=config/mac_mps.yaml
